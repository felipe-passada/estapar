{
  "title": "Estapar - Dashboard",
  "uid": "estapar-main",
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Requisições HTTP - Taxa por segundo",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"estapar\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência Webhook p99 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(api_webhook_request_seconds_bucket{application=\"estapar\"}[1m])) * 1000",
          "legendFormat": "p99 webhook",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(api_webhook_request_seconds_bucket{application=\"estapar\"}[1m])) * 1000",
          "legendFormat": "p95 webhook",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Erros HTTP (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 1 }
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_seconds_count{application=\"estapar\", outcome=\"SERVER_ERROR\"}[5m]))",
          "legendFormat": "Erros 5xx",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total de Eventos Webhook Recebidos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(http_server_requests_seconds_count{application=\"estapar\", uri=\"/webhook\"})",
          "legendFormat": "Total Webhooks",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Logs por Nível (Logback)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(logback_events_total{application=\"estapar\"}[1m])",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Uso de Memória JVM (Heap)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"estapar\", area=\"heap\"}",
          "legendFormat": "{{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_committed_bytes{application=\"estapar\", area=\"heap\"}",
          "legendFormat": "committed {{id}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "CPU - Processo e Sistema",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"estapar\"}",
          "legendFormat": "CPU Processo",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{application=\"estapar\"}",
          "legendFormat": "CPU Sistema",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Threads JVM",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jvm_threads_states_threads{application=\"estapar\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Conexões JDBC",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jdbc_connections_active{application=\"estapar\"}",
          "legendFormat": "Ativas",
          "refId": "A"
        },
        {
          "expr": "jdbc_connections_idle{application=\"estapar\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "jdbc_connections_max{application=\"estapar\"}",
          "legendFormat": "Máximo",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "title": "Duração de Queries por Repositório",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "rate(spring_data_repository_invocations_seconds_sum{application=\"estapar\"}[1m]) / rate(spring_data_repository_invocations_seconds_count{application=\"estapar\"}[1m])",
          "legendFormat": "{{repository}}.{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "GC - Pausas",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"estapar\"}[1m])",
          "legendFormat": "{{gc}} - {{cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Logs dos Containers (Loki)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{container_name=~\"estapar.*\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
